    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.39.1",
    "drizzle-zod": "^0.7.0",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.8.0",
    "zod": "^3.24.2",
    "esbuild": "^0.25.0"
  },
  "devDependencies": {
    "@types/express": "4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "20.16.11",
    "cross-env": "^7.0.3",
    "tsx": "^4.19.1",
    "typescript": "5.6.3"
  }
